{
  "expo": {
    "name": "Neuro-Synthetix",
    "slug": "neuro-synthetix",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "splash": {
      "backgroundColor": "#0E7C66",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "So you can describe your symptoms by voice."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "So you can describe your symptoms by voice."
      }
    },
    "android": {
      "package": "com.neurosynthetix.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "89fd7504-54d5-4dcc-8904-7a66fa8c2d28"
      }
    }
  }
}
